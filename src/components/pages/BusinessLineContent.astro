---
import type { Locale } from '../../i18n/config';
import type { BusinessLineSlug } from '../../i18n/paths';
import { getBusinessLine } from '../../i18n/dictionaries';
import { getLocalizedPath } from '../../i18n/paths';
import LabBranch from '../LabBranch.astro';

interface Props {
  locale: Locale;
  slug: BusinessLineSlug;
}

const { locale, slug } = Astro.props;
const line = getBusinessLine(locale, slug);

const lineOrder: BusinessLineSlug[] = ['synapse', 'mind', 'sense', 'flow', 'chain'];
const activeIndex = lineOrder.indexOf(slug);

const accentHeroBg: Record<typeof line.accent, string> = {
  cyan: 'from-brand-cyan/15 via-surface-muted to-surface',
  teal: 'from-brand-teal/15 via-surface-muted to-surface',
  mint: 'from-brand-mint/20 via-surface-muted to-surface',
  navy: 'from-brand-navy/10 via-surface-muted to-surface',
  ink: 'from-brand-ink/10 via-surface-muted to-surface',
};

const accentName: Record<typeof line.accent, string> = {
  cyan: 'text-brand-cyan',
  teal: 'text-brand-teal',
  mint: 'text-brand-teal',
  navy: 'text-brand-navy',
  ink: 'text-brand-navy',
};

const contactHref = `${getLocalizedPath(locale, 'contact')}?${locale === 'es' ? 'linea' : 'line'}=${slug}`;
---

<section class:list={['border-b border-brand-navy/10 bg-gradient-to-b', accentHeroBg[line.accent]]}>
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-[1fr_auto] lg:px-8">
    <div class="max-w-2xl">
      <p class:list={['font-display text-sm font-semibold tracking-[0.18em] uppercase', accentName[line.accent]]}>
        {line.name}
      </p>
      <h1 class="mt-3 font-display text-4xl font-bold text-brand-navy sm:text-5xl">
        {line.heroTitle}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-muted">{line.lead}</p>
    </div>
    <LabBranch activeIndex={activeIndex} variant="compact" />
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
  <h2 class="font-display text-2xl font-semibold text-brand-navy sm:text-3xl">
    {line.useCasesHeading}
  </h2>
  <div class="mt-10 space-y-10">
    {
      line.useCases.map((useCase) => (
        <article class="max-w-3xl border-l-2 border-brand-teal/40 pl-5">
          <h3 class="font-display text-xl font-semibold text-brand-navy">{useCase.title}</h3>
          <p class="mt-2 leading-relaxed text-ink-muted">{useCase.body}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="border-t border-brand-navy/10 bg-surface-muted">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <a
      href={contactHref}
      class="inline-flex rounded-sm bg-brand-navy px-5 py-2.5 text-sm font-semibold text-surface transition-colors hover:bg-brand-teal"
    >
      {line.ctaLabel}
    </a>
  </div>
</section>
