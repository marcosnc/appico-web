---
import type { Locale } from '../../i18n/config';
import { getDictionary } from '../../i18n/dictionaries';
import { getLocalizedPath } from '../../i18n/paths';
import BusinessLineCard from '../BusinessLineCard.astro';
import LabBranch from '../LabBranch.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
const contactHref = getLocalizedPath(locale, 'contact');
---

{/* Hero — brand signal is the living logo; copy supports it */}
<section class="relative overflow-hidden border-b border-brand-cyan/20">
  <div
    class="hero-atmosphere pointer-events-none absolute inset-0"
    aria-hidden="true"
  />
  {/* Soft horizontal wash — lab light, not neon */}
  <div
    class="pointer-events-none absolute -right-24 top-1/4 h-72 w-72 rounded-full bg-brand-mint/25 blur-3xl"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute -left-16 bottom-0 h-56 w-56 rounded-full bg-brand-cyan/20 blur-3xl"
    aria-hidden="true"
  />

  <div
    class="relative mx-auto grid max-w-6xl items-center gap-8 px-4 py-14 sm:px-6 sm:py-16 lg:grid-cols-2 lg:gap-8 lg:px-8 lg:py-20"
  >
    <div class="order-2 lg:order-1">
      <p class="font-display text-sm font-semibold tracking-[0.22em] text-brand-teal uppercase">
        {dict.home.tagline}
      </p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-brand-navy sm:text-5xl lg:text-6xl">
        {dict.home.brand}
      </h1>
      <p class="mt-5 max-w-md text-lg leading-relaxed text-ink-muted">
        {dict.home.lead}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={contactHref}
          class="inline-flex items-center justify-center rounded-sm bg-brand-navy px-5 py-2.5 text-sm font-semibold text-surface shadow-[0_8px_24px_rgba(10,48,87,0.22)] transition-colors hover:bg-brand-teal hover:shadow-[0_8px_24px_rgba(36,131,140,0.3)]"
        >
          {dict.home.ctaPrimary}
        </a>
        <a
          href="#business-lines"
          class="inline-flex items-center justify-center rounded-sm border border-brand-teal/40 bg-surface/70 px-5 py-2.5 text-sm font-semibold text-brand-navy backdrop-blur-sm transition-colors hover:border-brand-teal hover:text-brand-teal"
        >
          {dict.home.ctaSecondary}
        </a>
      </div>
    </div>

    <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
      <LabBranch
        variant="hero"
        label={locale === 'es' ? 'Appico Evolving Labs — cinco líneas' : 'Appico Evolving Labs — five lines'}
      />
    </div>
  </div>
</section>

{/* Business lines */}
<section id="business-lines" class="relative overflow-hidden bg-surface-muted">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-cyan/50 to-transparent"
    aria-hidden="true"
  />
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <h2 class="font-display text-3xl font-semibold text-brand-navy sm:text-4xl">
      {dict.home.linesHeading}
    </h2>
    <p class="mt-3 max-w-2xl text-ink-muted">{dict.home.linesLead}</p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        dict.businessLines.map((line) => (
          <BusinessLineCard line={line} locale={locale} ctaLabel={dict.home.lineCta} />
        ))
      }
    </div>
  </div>
</section>

{/* Closing CTA */}
<section class="relative overflow-hidden border-t border-brand-cyan/15">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_70%_50%,rgba(56,172,172,0.16),transparent_55%)]"
    aria-hidden="true"
  />
  <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <h2 class="max-w-2xl font-display text-3xl font-semibold text-brand-navy sm:text-4xl">
      {dict.home.closingHeading}
    </h2>
    <p class="mt-3 max-w-xl text-ink-muted">{dict.home.closingLead}</p>
    <a
      href={contactHref}
      class="mt-8 inline-flex items-center justify-center rounded-sm bg-brand-teal px-5 py-2.5 text-sm font-semibold text-surface shadow-[0_8px_24px_rgba(36,131,140,0.28)] transition-colors hover:bg-brand-navy"
    >
      {dict.home.closingCta}
    </a>
  </div>
</section>
