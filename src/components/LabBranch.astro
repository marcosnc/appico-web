---
/**
 * Lab mark — the Appico logo itself.
 * Same illuminate animation everywhere; only `variant` changes size.
 */
import logoSvg from '../assets/appico-logo-animated.svg?raw';

interface Props {
  variant?: 'hero' | 'compact' | 'mark';
  class?: string;
  label?: string;
}

const {
  variant = 'compact',
  class: className = '',
  label,
} = Astro.props;

const shellClass =
  variant === 'hero'
    ? 'w-full max-w-md sm:max-w-lg lg:max-w-xl'
    : variant === 'mark'
      ? 'w-16 h-16'
      : 'w-full max-w-xs sm:max-w-sm';
---

<div
  class:list={['lab-mark relative', shellClass, className]}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
>
  {
    variant !== 'mark' && (
      <div
        class="lab-glow pointer-events-none absolute left-1/2 top-1/2 h-[70%] w-[70%] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(79,216,203,0.4)_0%,rgba(56,172,172,0.18)_45%,transparent_70%)]"
        aria-hidden="true"
      />
    )
  }
  <div class="lab-logo relative w-full drop-shadow-[0_10px_32px_rgba(36,131,140,0.22)]" set:html={logoSvg} />
</div>
