---
import type { Locale } from '../i18n/config';
import { getDictionary } from '../i18n/dictionaries';
import { getLocalizedPath } from '../i18n/paths';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
const year = new Date().getFullYear();

const navLinks = [
  ...dict.businessLines.map((line) => ({
    href: getLocalizedPath(locale, line.slug),
    label: line.name,
  })),
  { href: getLocalizedPath(locale, 'about'), label: dict.nav.about },
  { href: getLocalizedPath(locale, 'contact'), label: dict.nav.contact },
];
---

<footer class="mt-auto bg-brand-ink text-surface">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-3 lg:px-8">
    <div class="space-y-4">
      <a href={getLocalizedPath(locale, 'home')} class="inline-flex items-center gap-2.5">
        <img
          src="/logo/appico-logo-transparente.svg"
          alt=""
          width="36"
          height="36"
          class="h-9 w-9 brightness-0 invert"
        />
        <span class="font-display text-lg font-semibold">Appico</span>
      </a>
      <p class="max-w-xs text-sm text-surface/70">{dict.footer.tagline}</p>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold tracking-wide text-brand-mint">
        {dict.footer.navigation}
      </h2>
      <ul class="mt-4 space-y-2">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-surface/80 transition-colors hover:text-brand-cyan"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold tracking-wide text-brand-mint">
        {dict.footer.contact}
      </h2>
      <p class="mt-4 text-sm text-surface/80">
        <a
          href={`mailto:${dict.footer.emailPlaceholder}`}
          class="transition-colors hover:text-brand-cyan"
        >
          {dict.footer.emailPlaceholder}
        </a>
      </p>
      <p class="mt-2 text-xs text-surface/45">
        {/* Placeholder until real contact details are provided */}
        {locale === 'es' ? 'Datos de contacto — pendiente' : 'Contact details — TBD'}
      </p>
    </div>
  </div>

  <div class="border-t border-surface/10">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-5 text-xs text-surface/50 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p>© {year} Appico. {dict.footer.rights}</p>
      <p class="font-display tracking-wide text-brand-cyan/80">Evolving Labs</p>
    </div>
  </div>
</footer>
